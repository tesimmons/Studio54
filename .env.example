###############################################################################
# Studio54 — Environment Configuration Template
# Copy to .env and fill in your values before starting services.
# NEVER commit .env to version control.
###############################################################################

#------------------------------------------------------------------------------
# Timezone
#------------------------------------------------------------------------------
TZ=America/New_York

#------------------------------------------------------------------------------
# Service Ports
# Change these if defaults conflict with other services on your host.
#------------------------------------------------------------------------------
STUDIO54_WEB_PORT=8009
STUDIO54_SERVICE_PORT=8010
STUDIO54_DB_PORT=5434
STUDIO54_REDIS_PORT=6381
STUDIO54_DOZZLE_PORT=9998

#------------------------------------------------------------------------------
# Database (PostgreSQL)
#------------------------------------------------------------------------------
STUDIO54_DB_NAME=studio54_db
STUDIO54_DB_USER=studio54
# REQUIRED — generate with: openssl rand -hex 32
STUDIO54_DB_PASSWORD=

#------------------------------------------------------------------------------
# Encryption Key
# REQUIRED — used to encrypt stored credentials.
# Generate with: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
#------------------------------------------------------------------------------
STUDIO54_ENCRYPTION_KEY=

#------------------------------------------------------------------------------
# Data Storage Paths
# These directories will be created by `./studio54 setup` if they do not exist.
#------------------------------------------------------------------------------
# Base directory for all Studio54 data (database, redis, cover art)
STUDIO54_DATA_DIR=/docker/studio54

# Path to your music library on the host (mounted read-write into the container)
MUSIC_LIBRARY_PATH=/music

# Path to your audiobooks library on the host
AUDIOBOOKS_PATH=/audiobooks

#------------------------------------------------------------------------------
# SABnzbd Downloader Integration (optional)
#------------------------------------------------------------------------------
SABNZBD_HOST=
SABNZBD_PORT=8080
SABNZBD_API_KEY=
# Directory where SABnzbd places completed music downloads
SABNZBD_DOWNLOAD_DIR=/downloads/music

#------------------------------------------------------------------------------
# AI / Ollama Integration (optional — used for smart metadata matching)
#------------------------------------------------------------------------------
OLLAMA_URL=http://localhost:11434
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
OLLAMA_MODEL=llama3.1:8b

#------------------------------------------------------------------------------
# External API Keys (all optional)
#------------------------------------------------------------------------------
# Fanart.tv — artist and album images
FANART_API_KEY=

# Last.fm — scrobbling and additional metadata
LASTFM_API_KEY=

# AcoustID — audio fingerprinting
ACOUSTID_API_KEY=

# AudD — music recognition
AUDD_API_TOKEN=

#------------------------------------------------------------------------------
# MusicBrainz Local Mirror (optional — eliminates remote API rate limits)
# Set MUSICBRAINZ_LOCAL_DB_ENABLED=true after running `./studio54 musicbrainzdb setup`
#------------------------------------------------------------------------------
MUSICBRAINZ_LOCAL_DB_URL=
MUSICBRAINZ_LOCAL_DB_ENABLED=false
# Remote API rate limit (requests per second)
MUSICBRAINZ_RATE_LIMIT=1.0

#------------------------------------------------------------------------------
# MUSE Integration (optional — duplicate detection service)
#------------------------------------------------------------------------------
MUSE_SERVICE_URL=

#------------------------------------------------------------------------------
# Celery Workers
#------------------------------------------------------------------------------
CELERY_LOG_LEVEL=info
# Max and min concurrent Celery workers (autoscale)
CELERY_AUTOSCALE_MAX=8
CELERY_AUTOSCALE_MIN=2

#------------------------------------------------------------------------------
# Watchtower (auto-updates) — only relevant if running the watchtower profile
# Enable with: docker compose --profile watchtower up -d
#------------------------------------------------------------------------------
# How often to check for updates (seconds); 86400 = daily
WATCHTOWER_INTERVAL=86400

# Per-service update control (true/false)
WATCHTOWER_STUDIO54_DB=false
WATCHTOWER_STUDIO54_REDIS=true
WATCHTOWER_STUDIO54_SERVICE=true
WATCHTOWER_STUDIO54_WORKER=true
WATCHTOWER_STUDIO54_BEAT=true
WATCHTOWER_STUDIO54_WEB=true
WATCHTOWER_DOZZLE=true
